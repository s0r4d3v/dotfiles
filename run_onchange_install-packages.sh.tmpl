#!/bin/bash
# Install packages — triggered when Brewfile changes
# Brewfile hash: {{ include "Brewfile" | sha256sum }}

set -euo pipefail

{{ if eq .chezmoi.os "darwin" -}}
if ! command -v brew &>/dev/null; then
    echo "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    if [ -f /opt/homebrew/bin/brew ]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [ -f /usr/local/bin/brew ]; then
        eval "$(/usr/local/bin/brew shellenv)"
    fi
fi
echo "Installing packages via Homebrew..."
brew bundle --file="{{ .chezmoi.sourceDir }}/Brewfile"

{{ else -}}
echo "Installing packages for Linux..."

# ─── apt packages ────────────────────────────────────────────────────────────
APT_PACKAGES=(
    curl
    wget
    git
    jq
    zsh
    tmux
    direnv
    shellcheck
    fzf
    bat
    fd-find
    ripgrep
    neovim
    imagemagick
    ghostscript
    nodejs
    npm
    autossh
    entr
)

echo "Installing apt packages..."
sudo apt-get update -qq
sudo DEBIAN_FRONTEND=noninteractive apt-get install -y -qq \
    -o DPkg::options::="--force-confdef" \
    -o DPkg::options::="--force-confold" \
    "${APT_PACKAGES[@]}"

# ─── Cargo/binary installs (tools not in apt or outdated) ────────────────────
# Load existing cargo env first (rustup may be installed but not in PATH yet)
source "$HOME/.cargo/env" 2>/dev/null || true

# Install rustup only if not already installed (check binary AND .rustup dir)
if ! command -v rustup &>/dev/null && [ ! -d "$HOME/.rustup" ]; then
    echo "Installing Rust toolchain..."
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --no-modify-path || true
    source "$HOME/.cargo/env" 2>/dev/null || true
fi

# Format: "package:binary" — binary is what's checked with command -v
CARGO_PACKAGES=(
    eza:eza
    btop:btop
    dust:dust
    duf:duf
    procs:procs
    bottom:btm
    tealdeer:tldr
    hyperfine:hyperfine
    bandwhich:bandwhich
    gping:gping
    trippy:trip
    sd:sd
    broot:broot
    git-cliff:git-cliff
    onefetch:onefetch
    lazygit:lazygit
    git-delta:delta
    difftastic:difft
    tokei:tokei
    just:just
    jless:jless
    gron:gron
    xh:xh
    yazi-fm:yazi
    viddy:viddy
    glow:glow
    starship:starship
    zoxide:zoxide
    atuin:atuin
    mprocs:mprocs
    posting:posting
    vhs:vhs
    asciinema:asciinema
)

# Install cargo-binstall for fast pre-compiled binary installs
if ! command -v cargo-binstall &>/dev/null; then
    echo "Installing cargo-binstall..."
    curl -L --proto '=https' --tlsv1.2 -sSf \
        https://raw.githubusercontent.com/cargo-bins/cargo-binstall/main/install-from-binstall-release.sh | bash
fi

echo "Installing cargo packages..."
for entry in "${CARGO_PACKAGES[@]}"; do
    pkg="${entry%%:*}"
    bin="${entry##*:}"
    if ! command -v "$bin" &>/dev/null; then
        echo "  Installing $pkg..."
        cargo binstall -y --no-confirm "$pkg" 2>/dev/null || echo "  Warning: failed to install $pkg"
    fi
done

# ─── Standalone installs ────────────────────────────────────────────────────
# age
if ! command -v age &>/dev/null; then
    echo "Installing age..."
    sudo apt-get install -y -qq age 2>/dev/null || {
        AGE_VERSION=$(curl -fsSL https://api.github.com/repos/FiloSottile/age/releases/latest | jq -r '.tag_name | ltrimstr("v")')
        curl -fsSL "https://dl.filippo.io/age/v${AGE_VERSION}?for=linux/amd64" | sudo tar -xz -C /usr/local/bin
    }
fi

# sops
if ! command -v sops &>/dev/null; then
    echo "Installing sops..."
    SOPS_VERSION=$(curl -fsSL https://api.github.com/repos/getsops/sops/releases/latest | jq -r .tag_name)
    curl -fsSL "https://github.com/getsops/sops/releases/download/${SOPS_VERSION}/sops-${SOPS_VERSION}.linux.amd64" -o /tmp/sops
    sudo install /tmp/sops /usr/local/bin/sops
fi

# gh (GitHub CLI)
if ! command -v gh &>/dev/null; then
    echo "Installing GitHub CLI..."
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | sudo dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | sudo tee /etc/apt/sources.list.d/github-cli.list > /dev/null
    sudo apt-get update -qq && sudo apt-get install -y -qq gh
    export PATH="/usr/bin:$PATH"
fi

# mise
if ! command -v mise &>/dev/null; then
    echo "Installing mise..."
    curl https://mise.run | sh
fi

# uv
if ! command -v uv &>/dev/null; then
    echo "Installing uv..."
    curl -LsSf https://astral.sh/uv/install.sh | sh
fi

# kubectl
if ! command -v kubectl &>/dev/null; then
    echo "Installing kubectl..."
    curl -fsSL "https://dl.k8s.io/release/$(curl -fsSL https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl" -o /tmp/kubectl
    sudo install /tmp/kubectl /usr/local/bin/kubectl
fi

# helm
if ! command -v helm &>/dev/null; then
    echo "Installing helm..."
    curl https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash
fi

# terraform
if ! command -v terraform &>/dev/null; then
    echo "Installing terraform..."
    sudo apt-get install -y -qq gnupg software-properties-common
    curl -fsSL https://apt.releases.hashicorp.com/gpg | sudo gpg --dearmor -o /usr/share/keyrings/hashicorp-archive-keyring.gpg
    echo "deb [signed-by=/usr/share/keyrings/hashicorp-archive-keyring.gpg] https://apt.releases.hashicorp.com $(lsb_release -cs) main" | sudo tee /etc/apt/sources.list.d/hashicorp.list > /dev/null
    sudo apt-get update -qq && sudo apt-get install -y -qq terraform
fi

# doggo (DNS client — Go binary, not on crates.io)
if ! command -v doggo &>/dev/null; then
    echo "Installing doggo..."
    DOGGO_VERSION=$(curl -fsSL https://api.github.com/repos/mr-karan/doggo/releases/latest | jq -r '.tag_name | ltrimstr("v")')
    curl -fsSL "https://github.com/mr-karan/doggo/releases/download/v${DOGGO_VERSION}/doggo_${DOGGO_VERSION}_linux_amd64.tar.gz" | tar -xz -C /tmp doggo
    sudo install /tmp/doggo /usr/local/bin/doggo
fi

# trash-cli (Python)
if ! command -v trash-put &>/dev/null; then
    echo "Installing trash-cli..."
    pip3 install --user trash-cli 2>/dev/null || sudo apt-get install -y -qq trash-cli
fi

# claude-code (Anthropic Claude CLI)
if ! command -v claude &>/dev/null; then
    echo "Installing Claude Code..."
    npm install -g @anthropic-ai/claude-code
fi

echo "Done! Some tools may need a shell restart to be available."
{{ end -}}
