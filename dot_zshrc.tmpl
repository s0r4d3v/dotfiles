alias ls="eza"
alias ll="eza -la"
alias la="eza -a"
alias lt="eza --tree"
alias l="eza -l"

# File viewing
alias cat="bat"
alias less="bat --paging=always"

# Git
alias lg="lazygit"

# Ghq
alias repo='cd $(ghq list --full-path | fzf)'

# Mount
alias mnt='cd ~/mnt/$(ls ~/mnt | fzf)'

# Editor
alias v="nvim"
alias vi="nvim"
alias vim="nvim"

# Navigation
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."

# Safety
{{- if eq .chezmoi.os "darwin" }}
alias rm="trash"
{{- else }}
alias rm="trash-put"
{{- end }}
alias cp="cp -i"
alias mv="mv -i"

# System
alias top="btop"
alias du="dust"
alias df="duf"
alias help="tealdeer"
alias tldr="tealdeer"
alias cd="z"
alias cdi="zi"
alias ps="procs"

# Tmux
alias tm="tmux"

# HTTP
alias http="xh"
alias https="xh --https"

# Opencode
alias oc="opencode"

# Docker
alias lzd="lazydocker"

# Kubernetes
alias k="kubectl"
alias kl="stern"
