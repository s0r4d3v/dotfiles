# ============================================================
# Environment
# ============================================================
{{ if eq .chezmoi.os "darwin" -}}
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
{{ else -}}
export LANG=C.UTF-8
export LC_ALL=C.UTF-8
{{ end -}}

export DOTFILES_PATH="$(ghq root)/github.com/s0r4d3v/dotfiles"
export PATH="$HOME/.local/bin:$HOME/.npm-global/bin:$PATH"

# ============================================================
# Zsh completions
# ============================================================
{{ if eq .chezmoi.os "darwin" -}}
if type brew &>/dev/null; then
  FPATH="$(brew --prefix)/share/zsh-completions:$(brew --prefix)/share/zsh/site-functions:$FPATH"
fi
{{ end -}}
autoload -Uz compinit
compinit

# ============================================================
# Zsh plugins
# ============================================================
{{ if eq .chezmoi.os "darwin" -}}
source "$(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
source "$(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
{{ else -}}
[ -f /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh ] && \
  source /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh
[ -f /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ] && \
  source /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
{{ end -}}

# ============================================================
# Tool initializations
# ============================================================
eval "$(starship init zsh)"
eval "$(zoxide init zsh)"
eval "$(fzf --zsh)"
eval "$(atuin init zsh)"
eval "$(direnv hook zsh)"
eval "$(mise activate zsh)"

# ============================================================
# Aliases
# ============================================================

# File listing (eza)
alias ls="eza"
alias ll="eza -la"
alias la="eza -a"
alias lt="eza --tree"
alias l="eza -l"

# File viewing
alias cat="bat"
alias less="bat --paging=always"

# Git
alias lg="lazygit"

# Ghq
alias repo="cd \$(ghq list --full-path | fzf)"

# Mount
alias mnt="cd ~/mnt/\$(ls ~/mnt | fzf)"

# Editor
alias v="nvim"
alias vi="nvim"
alias vim="nvim"

# Navigation
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."

# Safety
alias rm="trash-put"
alias cp="cp -i"
alias mv="mv -i"

# System
alias top="btop"
alias du="dust"
alias df="duf"
alias help="tealdeer"
alias tldr="tealdeer"
alias cd="z"
alias cdi="zi"
alias ps="procs"

# Tmux
alias tm="tmux"

# HTTP
alias http="xh"
alias https="xh --https"

# Opencode
alias oc="opencode"

# Docker
alias lzd="lazydocker"

# Kubernetes
alias k="kubectl"
alias kl="stern"
alias kns="kubens"

# Diff
alias diff="difft"

# Watch
alias watch="viddy"

# Markdown
alias md="glow"

# ============================================================
# Functions
# ============================================================

# Tmux development session
function dev() {
  local session_name
  if [[ $# -eq 0 ]]; then
    session_name=$(basename $PWD)
  else
    session_name=$1
  fi
  if tmux has-session -t "$session_name" 2>/dev/null; then
    tmux attach-session -t "$session_name"
  else
    tmux new-session -s "$session_name" -c "$PWD" nvim
  fi
}

# Make directory and cd into it
function mkcd() {
  mkdir -p "$1" && cd "$1"
}

# Extract various archive formats
function extract() {
  if [[ $# -ne 1 ]]; then
    echo "Usage: extract <archive>"
    return 1
  fi
  if [[ ! -f "$1" ]]; then
    echo "Error: '$1' is not a valid file"
    return 1
  fi
  case "$1" in
    *.tar.bz2) tar xjf "$1" ;;
    *.tar.gz)  tar xzf "$1" ;;
    *.tar.xz)  tar xJf "$1" ;;
    *.bz2)     bunzip2 "$1" ;;
    *.rar)     unrar x "$1" ;;
    *.gz)      gunzip "$1" ;;
    *.tar)     tar xf "$1" ;;
    *.tbz2)    tar xjf "$1" ;;
    *.tgz)     tar xzf "$1" ;;
    *.zip)     unzip "$1" ;;
    *.Z)       uncompress "$1" ;;
    *.7z)      7z x "$1" ;;
    *) echo "Error: '$1' cannot be extracted via extract()" ; return 1 ;;
  esac
}

# Quick backup of a file
function backup() {
  if [[ $# -ne 1 ]]; then
    echo "Usage: backup <file>"
    return 1
  fi
  cp "$1" "$1.bak.$(date +%Y%m%d_%H%M%S)"
}

# Find processes using a port
function port() {
  if [[ $# -ne 1 ]]; then
    echo "Usage: port <port_number>"
    return 1
  fi
  lsof -i :"$1"
}
