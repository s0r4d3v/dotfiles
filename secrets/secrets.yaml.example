# secrets/secrets.yaml.example
# このファイルは実際のシークレットのテンプレートです。
#
# 実際のシークレットファイルを作成するには：
#   sops secrets/secrets.yaml
#
# エディタが開いたら、以下の内容を参考に実際の値を入力してください。

ssh-private-key-ed25519: |
  -----BEGIN OPENSSH PRIVATE KEY-----
  YOUR_PRIVATE_KEY_HERE
  -----END OPENSSH PRIVATE KEY-----
ssh-public-key-ed25519: "ssh-ed25519 AAAA... your-email@example.com"
ssh-private-key-tanaka-site: |
  -----BEGIN OPENSSH PRIVATE KEY-----
  YOUR_PRIVATE_KEY_HERE
  -----END OPENSSH PRIVATE KEY-----
github-token: "ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
