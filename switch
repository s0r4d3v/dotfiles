#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "${REPO_DIR}"

if git fetch --quiet origin 2>/dev/null; then
  LOCAL=$(git rev-parse HEAD)
  REMOTE=$(git rev-parse '@{u}' 2>/dev/null || echo "${LOCAL}")
  if [[ "${LOCAL}" != "${REMOTE}" ]]; then
    if ! git diff --quiet || ! git diff --cached --quiet; then
      echo "Warning: local uncommitted changes detected — skipping pull. Commit or stash them first."
    else
      echo "Pulling latest changes..."
      git pull --ff-only
    fi
  fi
fi

USERNAME=$(whoami)
ARCH=$(uname -m)
OS=$(uname -s)

case "${ARCH}" in
  arm64|aarch64) NIX_ARCH="aarch64" ;;
  x86_64)        NIX_ARCH="x86_64"  ;;
  *) echo "Unsupported architecture: ${ARCH}"; exit 1 ;;
esac

FLAKE=".#${USERNAME}-${NIX_ARCH}"

update_homebrew_if_needed() {
  local brew_bin=""
  local brew_repo=""
  local core_repo=""
  local cask_repo=""

  if [[ -x /opt/homebrew/bin/brew ]]; then
    brew_bin="/opt/homebrew/bin/brew"
    brew_repo="/opt/homebrew/Library/Homebrew"
    core_repo="/opt/homebrew/Library/Taps/homebrew/homebrew-core"
    cask_repo="/opt/homebrew/Library/Taps/homebrew/homebrew-cask"
  elif [[ -x /usr/local/bin/brew ]]; then
    brew_bin="/usr/local/bin/brew"
    brew_repo="/usr/local/Homebrew"
    core_repo="/usr/local/Homebrew/Library/Taps/homebrew/homebrew-core"
    cask_repo="/usr/local/Homebrew/Library/Taps/homebrew/homebrew-cask"
  else
    return 0
  fi

  echo "Checking Homebrew..."

  # Fast path: brew works
  if "${brew_bin}" --version >/dev/null 2>&1; then
    echo "Updating Homebrew..."
    "${brew_bin}" update || true
    return 0
  fi

  echo "brew is unhealthy — attempting Git-based Homebrew refresh..."

  if [[ -d "${brew_repo}/.git" ]]; then
    git -C "${brew_repo}" fetch origin
    git -C "${brew_repo}" checkout main || true
    git -C "${brew_repo}" pull --ff-only
  fi

  if [[ -d "${core_repo}/.git" ]]; then
    git -C "${core_repo}" fetch origin
    git -C "${core_repo}" checkout main || true
    git -C "${core_repo}" pull --ff-only
  fi

  if [[ -d "${cask_repo}/.git" ]]; then
    git -C "${cask_repo}" fetch origin
    git -C "${cask_repo}" checkout main || true
    git -C "${cask_repo}" pull --ff-only
  fi

  echo "Re-checking Homebrew..."
  "${brew_bin}" --version >/dev/null 2>&1 || {
    echo "Homebrew is still failing after refresh."
    echo "Try reinstalling Homebrew with the official installer, then rerun ./switch."
    exit 1
  }

  "${brew_bin}" update || true
}

case "${OS}" in
  Darwin)
    echo "Applying darwin config: ${FLAKE}"

    update_homebrew_if_needed

    if command -v darwin-rebuild >/dev/null 2>&1; then
      sudo darwin-rebuild switch --flake "${FLAKE}" "$@"
    else
      echo "(darwin-rebuild not found — bootstrapping via nix build)"
      nix --extra-experimental-features 'nix-command flakes' \
        build nix-darwin#darwin-rebuild
      sudo ./result/bin/darwin-rebuild switch --flake "${FLAKE}" "$@"
    fi
    ;;
  Linux)
    echo "Applying home-manager config: ${FLAKE}"
    if command -v home-manager >/dev/null 2>&1; then
      home-manager switch --flake "${FLAKE}" "$@"
    else
      echo "(home-manager not found — bootstrapping via nix run)"
      nix --extra-experimental-features 'nix-command flakes' \
        run home-manager/master -- switch --flake "${FLAKE}" "$@"
    fi
    ;;
  *) echo "Unsupported OS: ${OS}"; exit 1 ;;
esac
