{{- $ageKey := joinPath .chezmoi.homeDir ".config/sops/age/keys.txt" -}}
{{- if not (stat $ageKey) -}}
{{-   fail (printf "Age key not found at %s\nRestore it from your password manager before running chezmoi apply." $ageKey) -}}
{{- end -}}
{{- $name := promptStringOnce . "name" "Your name" -}}
{{- $email := promptStringOnce . "email" "Your email" -}}
{{- warnf "chezmoi: using name=%q email=%q" $name $email -}}

encryption = "age"

[age]
identity = "~/.config/sops/age/keys.txt"
recipient = "age1gxcqm7f4m226vmakn3r6evxs8wc85ck2h0lkss9tfskxszg50uesn35x8q"

[data]
name = {{ $name | quote }}
email = {{ $email | quote }}
