#!/bin/sh
# Claude Code hook — blocks bare `rm -rf` calls, suggests trash instead.
input=$(cat)
cmd=$(echo "$input" | jq -r '.tool_input.command // ""')
if echo "$cmd" | grep -qE '^rm[[:space:]].*-(rf?|r?f)\b'; then
    echo "❌ Blocked: Use 'trash' instead of 'rm -rf' for safety" >&2
    echo "💡 trash-put is available in your PATH" >&2
    exit 2
fi
