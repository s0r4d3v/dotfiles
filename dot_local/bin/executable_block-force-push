#!/bin/sh
# Claude Code hook — blocks force-push to main/master.
input=$(cat)
cmd=$(echo "$input" | jq -r '.tool_input.command // ""')
if echo "$cmd" | grep -qE 'git[[:space:]]+push[[:space:]].*(-f|--force).*(main|master)'; then
    echo "❌ Blocked: Force push to main/master is prohibited" >&2
    echo "💡 Create a feature branch instead" >&2
    exit 2
fi
